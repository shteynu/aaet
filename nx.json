{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "analytics": false,
  "plugins": [
    {
      "plugin": "@nx/eslint/plugin",
      "options": {
        "targetName": "lint"
      }
    }
  ],
  "targetDefaults": {
    "test": {
      "cache": true
    },
    "analyze": {
      "cache": true
    },
    "typecheck": {
      "cache": true
    },
    "build": {
      "cache": true
    },
    "lint": {
      "cache": true
    }
  }
}
